# Copy this file to .env and fill in your own values.
# Never commit .env. Every value below is a placeholder.

# --- Trakt (OAuth device flow) ---
# Register an application at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your-trakt-client-id
TRAKT_CLIENT_SECRET=your-trakt-client-secret

# --- TMDB (candidates, metadata, ID resolution) ---
# Create a key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
TMDB_LANGUAGE=en-US

# --- AI curation (OpenAI-compatible chat completions endpoint) ---
AI_BASE_URL=https://your-provider.example/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=glm-5.2
AI_CURATOR_TIMEOUT_MS=120000

# --- Embeddings (OpenAI-compatible embeddings endpoint) ---
EMBED_BASE_URL=https://your-provider.example/v1
EMBED_API_KEY=your-embedding-api-key
EMBED_MODEL=qwen3-embedding-8b

# --- Turso/libSQL database ---
# turso db show <db> --url  /  turso db tokens create <db>
TURSO_URL=libsql://your-database.turso.io
TURSO_TOKEN=your-turso-token

# --- Addon ---
ADDON_URL=https://your-domain.example
PORT=3000

# Optional: future admin setup wizard protection.
# SETUP_TOKEN=change-this-admin-token
# APP_SECRET=change-this-long-random-secret
